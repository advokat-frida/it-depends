{
  "name": "it-depends",
  "version": "0.1.1",
  "private": true,
  "description": "IT DEPENDS - a shared-screen privacy decision game from Advokat Frida.",
  "engines": {
    "node": ">=22.13.0"
  },
  "type": "module",
  "scripts": {
    "build": "node tools/build.mjs",
    "dev": "npm run build && node harness/server.mjs",
    "package": "npm run build && node tools/package.mjs",
    "test": "npm run build && vitest run",
    "harness": "npm run build && node harness/checks.mjs",
    "harness:art": "npm run build && node harness/capture-art.mjs",
    "harness:flip": "npm run build && node harness/capture-flip.mjs",
    "harness:offline": "npm run build && node harness/offline.mjs",
    "verify:standalone": "node tools/verify-standalone.mjs",
    "qa": "npm test && npm run harness && npm run harness:offline && npm run harness:flip && npm run package && npm run verify:standalone"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "esbuild": "0.28.1",
    "fflate": "0.8.3",
    "playwright": "1.61.1",
    "vitest": "4.1.10"
  }
}
